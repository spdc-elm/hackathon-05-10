# LLM provider. First supported target: openai_compatible.
LLM_PROVIDER=openai_compatible

# OpenAI-compatible chat completions endpoint.
# Examples:
# - https://api.openai.com/v1
# - https://api.deepseek.com
# - https://dashscope.aliyuncs.com/compatible-mode/v1
# - Any ModelScope or custom endpoint that speaks OpenAI-compatible API.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# Optional future provider. Not required for the first vertical slice.
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Runtime data directory. Ignored by Git.
RUNTIME_DIR=data/runtime

# Obsidian-compatible vault directory. Ignored by Git.
VAULT_DIR=data/vault
